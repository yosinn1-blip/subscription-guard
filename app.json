{
  "expo": {
    "name": "Subscription Guard",
    "slug": "subscription-guard",
    "scheme": "subscription-guard",
    "version": "1.0.0",
    "platforms": [
      "ios"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F5F0"
    },
    "ios": {
      "bundleIdentifier": "com.yoshiki.subscriptionguard",
      "supportsTablet": false,
      "buildNumber": "5",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "トライアル終了前日にリマインドするために通知を使用します。",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#5C8A6E",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "065fbf61-a732-4075-b773-eb63399125a6"
      }
    },
    "privacyPolicyUrl": "https://yosinn1-blip.github.io/subscription-guard/privacy.html",
    "owner": "yosinn"
  }
}
